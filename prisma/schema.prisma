generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model PortalProject {
  id            String   @id @default(cuid())
  projectId     String   @unique
  name          String
  isVisible     Boolean  @default(true)
  displayOrder  Int      @default(0)
  initialSize   String   @default("full")  // collapsed or full (medium removed)
  screenshots   String[] @default([])
  // Editable overrides - if set, these override the default data
  clientOverride    String?
  titleOverride     String?
  subtitleOverride  String?
  iconOverride      String?
  colorOverride     String?   // Custom gradient color
  metricsOverride   Json?    // Array of {value, label} objects
  // Header badge (all projects get one)
  flagshipBadge     String?
  // Content sections
  challengeOverride   String?
  solutionOverride    String?
  technicalOverride   Json?    // Array of {area, icon, details} objects
  outcomesOverride    Json?    // Array of {text} objects
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Site-wide settings for admin controls
model SiteSettings {
  id                    String   @id @default("settings")
  advocateChatEnabled   Boolean  @default(true)
  testimonialsEnabled   Boolean  @default(true)
  // Job tailoring settings
  jobTailorActive       Boolean  @default(false)
  jobTailorExpiry       DateTime?
  jobTailorData         Json?    // Stores the current tailored state
  jobTailorDefaults     Json?    // Stores the default/base state
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Editable content sections
model SectionContent {
  id          String   @id @default(cuid())
  sectionId   String   @unique  // about, resume, experience, ai
  content     Json     // Section-specific editable content
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI Context entries for the Career Advocate chatbot
model ContextEntry {
  id          String   @id @default(cuid())
  projectId   String   // e.g., pe-demo, wrights-media, general
  projectName String   // Human-readable project name
  type        String   // url, note, detail
  content     String   // The actual context content
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Chat logs for Career Advocate conversations
model ChatLog {
  id            String   @id @default(cuid())
  sessionId     String   // Unique session identifier
  role          String   // user or assistant
  content       String   // Message content
  // User metadata
  userAgent     String?
  ipAddress     String?
  referrer      String?
  companyDetected String?
  // Timestamps
  createdAt     DateTime @default(now())
}

// Code Showcase entries for displaying scripts and configurations
model CodeShowcase {
  id            String   @id @default(cuid())
  title         String   // Display title
  description   String   // Brief description of what the code does
  language      String   // html, sql, python
  code          String   // The actual code content
  fileName      String?  // Optional file name for display
  category      String   @default("general") // automation, infrastructure, data, etc.
  isVisible     Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Testimonials from colleagues and clients
model Testimonial {
  id            String   @id @default(cuid())
  name          String   // Person's name
  title         String   // Job title
  company       String   // Company name
  linkedinUrl   String?  // LinkedIn profile URL
  imageUrl      String?  // Profile image URL
  content       String   // The testimonial text
  relationship  String?  // e.g., "Manager at Thomas Inv", "Colleague at Zuar"
  isVisible     Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
